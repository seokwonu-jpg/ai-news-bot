# Gemini API 키 (Google AI Studio에서 무료 발급)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CURATOR_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARIZER_MODEL=gemini-2.5-flash

# Optional LLM provider override
# Supported: gemini, litellm
LLM_PROVIDER=gemini
# LLM_CURATOR_PROVIDER=gemini
# LLM_SUMMARIZER_PROVIDER=gemini

# Optional LiteLLM gateway settings
LITELLM_API_BASE=https://litellm.iaiai.ai/v1
LITELLM_API_KEY=
LITELLM_MODEL=gpt-5.4
LITELLM_CURATOR_MODEL=gpt-5-mini
LITELLM_SUMMARIZER_MODEL=gpt-5.4

# Slack Incoming Webhook URL
# Slack 채널 → 앱 추가 → Incoming Webhooks → Webhook URL 복사
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# 긴급 알림 전용 Webhook URL (없으면 SLACK_WEBHOOK_URL 재사용)
SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional runtime overrides
DAILY_FETCH_HOURS=24
DAILY_TOP_N=8
ALERT_FETCH_HOURS=12
ALERT_MAX_ITEMS=3
ALERT_MIN_SCORE=6.0
SOURCE_HEALTHCHECK_HOURS=168
